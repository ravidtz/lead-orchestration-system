# ─── Web (apps/web/.env.local) ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_URL=http://localhost:3001/v1

# ─── API (apps/api/.env) ─────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Database (Supabase direct connection string)
DATABASE_URL=

# Anthropic
ANTHROPIC_API_KEY=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Deepgram
DEEPGRAM_API_KEY=

# ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Security
API_KEY_SALT=change_me_32_char_random_string__
WEBHOOK_SIGNING_SECRET=change_me_32_char_random_string__

# Redis
REDIS_URL=redis://localhost:6379

# CORS
ALLOWED_ORIGIN=http://localhost:3000
